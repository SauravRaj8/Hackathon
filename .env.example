# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/catalogue_db

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=catalogue_products

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Quality Scoring
# Items with AI match score below this threshold go to MongoDB pending
QUALITY_THRESHOLD=0.75
